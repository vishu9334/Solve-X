# ─── Stage 1: Build frontend ─────────────────────────────────────────────────
FROM node:20-alpine AS frontend-builder
WORKDIR /app/xClient
COPY xClient/package*.json ./
RUN npm ci
COPY xClient/ .
RUN npm run build

# ─── Stage 2: Build backend ───────────────────────────────────────────────────
FROM node:20-alpine AS backend-builder
WORKDIR /app/xServer
COPY xServer/package*.json ./
RUN npm ci
COPY xServer/ .

# ─── Stage 3: Final production image ─────────────────────────────────────────
FROM node:20-alpine
WORKDIR /app/xServer

# Copy backend
COPY --from=backend-builder --chown=node:node /app/xServer ./

# Copy built frontend into expected location
COPY --from=frontend-builder --chown=node:node /app/xClient/dist /app/xClient/dist

USER node
EXPOSE 8001
CMD ["node", "server.js"]